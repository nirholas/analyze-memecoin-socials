# Environment variables
.env

# Data files (generated by scripts, can be large)
# Note: /data/ is the scripts data folder, NOT web/public/data/
# Unignored: data/pump-sdk/ is tracked for the case study
/data/*
!/data/pump-sdk/
*.duckdb
*.duckdb-wal
*.duckdb-shm
*.db
*.db-shm
*.db-wal

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Output
*.html
!chart/*.html
reports/

# Backup archives
*_backup_*.zip

# Research/analysis work (not part of main app)
/analysis/

.vercel

# Allow chart visualization and research data
!web/chart.html
!/data/pump-sdk-*.json
!/data/pump-sdk-*.csv
